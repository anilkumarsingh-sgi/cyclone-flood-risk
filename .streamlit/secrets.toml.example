# Example Streamlit secrets — copy to secrets.toml and fill in.
# DO NOT commit secrets.toml to git.

# Google Places API (used by Hazard Proximity page + geocoding)
GOOGLE_PLACES_API_KEY = "YOUR_GOOGLE_PLACES_API_KEY"

# Optional: Earth Engine service-account credentials
# Generate a service account in GCP, give it the "Earth Engine Resource Viewer"
# role + register it at https://signup.earthengine.google.com/#!/service_accounts
# You can use either [earthengine] or [json_key] section.
[earthengine]
type = "service_account"
project_id = "your-ee-project-id"
private_key_id = "your-private-key-id"
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-sa@your-project-id.iam.gserviceaccount.com"
token_uri = "https://oauth2.googleapis.com/token"

# Same shape also works under this section name if you prefer:
# [json_key]
